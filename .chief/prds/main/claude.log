{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0184LHzqd8yh7wHi7N3egaNo","type":"tool_result","content":"     1→import { supabase } from \"./supabase\";\n     2→import type { Connection } from \"./connections\";\n     3→\n     4→const SESSION_KEY = \"linjer_session_id\";\n     5→const SUBMITTED_KEY = \"linjer_submitted\";\n     6→const CONNECTIONS_KEY = \"linjer_connections\";\n     7→\n     8→function getSessionId(): string {\n     9→  let id = localStorage.getItem(SESSION_KEY);\n    10→  if (!id) {\n    11→    id = crypto.randomUUID();\n    12→    localStorage.setItem(SESSION_KEY, id);\n    13→  }\n    14→  return id;\n    15→}\n    16→\n    17→export function isSubmitted(): boolean {\n    18→  return localStorage.getItem(SUBMITTED_KEY) === \"true\";\n    19→}\n    20→\n    21→export function getStoredConnections(): Connection[] {\n    22→  const raw = localStorage.getItem(CONNECTIONS_KEY);\n    23→  if (!raw) return [];\n    24→  try {\n    25→    return JSON.parse(raw) as Connection[];\n    26→  } catch {\n    27→    return [];\n    28→  }\n    29→}\n    30→\n    31→/**\n    32→ * Submit connections to Supabase.\n    33→ * Box indices are 0-based internally — we store 1-based in the DB.\n    34→ */\n    35→export async function submitConnections(\n    36→  connections: Connection[],\n    37→): Promise<void> {\n    38→  const sessionId = getSessionId();\n    39→\n    40→  const rows = connections.map((c) => ({\n    41→    session_id: sessionId,\n    42→    source_box: c.source + 1,\n    43→    target_box: c.target + 1,\n    44→  }));\n    45→\n    46→  const { error } = await supabase.from(\"connections\").insert(rows);\n    47→\n    48→  if (error) {\n    49→    throw new Error(error.message);\n    50→  }\n    51→\n    52→  // Mark as submitted in localStorage\n    53→  localStorage.setItem(SUBMITTED_KEY, \"true\");\n    54→  localStorage.setItem(CONNECTIONS_KEY, JSON.stringify(connections));\n    55→}\n    56→"}]},"parent_tool_use_id":"toolu_018WJAUjD9ESpKefa8YqHEoo","session_id":"5713111b-d6f1-430e-8ec1-2314c52440c9","uuid":"3cea6cf2-481f-4aa3-8185-91cf3e83cc6c"}
