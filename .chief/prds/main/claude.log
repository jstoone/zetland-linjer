{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LK72soRS3naxu5Xu4aazFD","type":"tool_result","content":"     1→import { Application } from \"pixi.js\";\n     2→import { createGrid } from \"./grid\";\n     3→import { Connection, setupConnections } from \"./connections\";\n     4→import { isSubmitted, getStoredConnections, submitConnections } from \"./submit\";\n     5→import { createResultsRenderer } from \"./results\";\n     6→\n     7→const app = new Application();\n     8→\n     9→await app.init({\n    10→  background: \"#1a1a2e\",\n    11→  resizeTo: window,\n    12→  antialias: true,\n    13→  resolution: window.devicePixelRatio || 1,\n    14→  autoDensity: true,\n    15→});\n    16→\n    17→document.body.appendChild(app.canvas);\n    18→\n    19→const boxes = createGrid(app);\n    20→const manager = setupConnections(app, boxes);\n    21→const results = createResultsRenderer(app, boxes);\n    22→\n    23→// --- UI elements ---\n    24→const resetBtn = document.getElementById(\"reset-btn\") as HTMLButtonElement;\n    25→const undoToast = document.getElementById(\"undo-toast\") as HTMLDivElement;\n    26→const submitBtn = document.getElementById(\"submit-btn\") as HTMLButtonElement;\n    27→const resultsBtn = document.getElementById(\"results-btn\") as HTMLButtonElement;\n    28→const submitError = document.getElementById(\"submit-error\") as HTMLDivElement;\n    29→\n    30→let submitted = isSubmitted();\n    31→\n    32→// Restore connections from localStorage if previously submitted\n    33→if (submitted) {\n    34→  const stored = getStoredConnections();\n    35→  manager.connections.push(...stored);\n    36→  manager.redraw();\n    37→  resultsBtn.style.display = \"\";\n    38→}\n    39→let undoBackup: Connection[] | null = null;\n    40→let undoTimer: ReturnType<typeof setTimeout> | null = null;\n    41→\n    42→function updateButtonVisibility() {\n    43→  if (submitted) {\n    44→    resetBtn.style.display = \"none\";\n    45→    submitBtn.style.display = \"none\";\n    46→    return;\n    47→  }\n    48→  const hasConnections = manager.connections.length > 0;\n    49→  resetBtn.style.display = hasConnections ? \"\" : \"none\";\n    50→  submitBtn.style.display = hasConnections ? \"\" : \"none\";\n    51→}\n    52→\n    53→// Poll visibility cheaply via animation frame (connections change from pointer events)\n    54→function tick() {\n    55→  updateButtonVisibility();\n    56→  requestAnimationFrame(tick);\n    57→}\n    58→requestAnimationFrame(tick);\n    59→\n    60→// --- Reset button + undo toast ---\n    61→resetBtn.addEventListener(\"click\", () => {\n    62→  const removed = manager.resetAll();\n    63→  if (removed.length === 0) return;\n    64→\n    65→  undoBackup = removed;\n    66→  undoToast.style.display = \"\";\n    67→  resetBtn.style.display = \"none\";\n    68→  submitBtn.style.display = \"none\";\n    69→\n    70→  if (undoTimer) clearTimeout(undoTimer);\n    71→  undoTimer = setTimeout(() => {\n    72→    undoBackup = null;\n    73→    undoToast.style.display = \"none\";\n    74→    undoTimer = null;\n    75→  }, 3000);\n    76→});\n    77→\n    78→undoToast.addEventListener(\"click\", () => {\n    79→  if (!undoBackup) return;\n    80→  manager.connections.push(...undoBackup);\n    81→  manager.redraw();\n    82→  undoBackup = null;\n    83→  undoToast.style.display = \"none\";\n    84→  if (undoTimer) {\n    85→    clearTimeout(undoTimer);\n    86→    undoTimer = null;\n    87→  }\n    88→});\n    89→\n    90→// --- Submit button ---\n    91→submitBtn.addEventListener(\"click\", async () => {\n    92→  if (submitted || manager.connections.length === 0) return;\n    93→\n    94→  submitBtn.disabled = true;\n    95→  submitBtn.textContent = \"Sender...\";\n    96→  submitError.style.display = \"none\";\n    97→\n    98→  try {\n    99→    await submitConnections(manager.connections);\n   100→    submitted = true;\n   101→    submitBtn.style.display = \"none\";\n   102→    resetBtn.style.display = \"none\";\n   103→    resultsBtn.style.display = \"\";\n   104→  } catch {\n   105→    submitBtn.disabled = false;\n   106→    submitBtn.textContent = \"Send\";\n   107→    submitError.textContent = \"Noget gik galt — prøv igen\";\n   108→    submitError.style.display = \"\";\n   109→    setTimeout(() => {\n   110→      submitError.style.display = \"none\";\n   111→    }, 4000);\n   112→  }\n   113→});\n   114→\n   115→// --- Results button ---\n   116→resultsBtn.addEventListener(\"click\", async () => {\n   117→  resultsBtn.disabled = true;\n   118→  resultsBtn.textContent = \"Henter...\";\n   119→\n   120→  try {\n   121→    await results.showResults(manager.connections);\n   122→    resultsBtn.textContent = \"Opdater resultater\";\n   123→  } catch {\n   124→    resultsBtn.textContent = \"Se resultater\";\n   125→    submitError.textContent = \"Kunne ikke hente resultater\";\n   126→    submitError.style.display = \"\";\n   127→    setTimeout(() => {\n   128→      submitError.style.display = \"none\";\n   129→    }, 4000);\n   130→  } finally {\n   131→    resultsBtn.disabled = false;\n   132→  }\n   133→});\n   134→"}]},"parent_tool_use_id":"toolu_018WJAUjD9ESpKefa8YqHEoo","session_id":"5713111b-d6f1-430e-8ec1-2314c52440c9","uuid":"eae4a993-9ea6-4705-9a0d-960e05c4f19d"}
