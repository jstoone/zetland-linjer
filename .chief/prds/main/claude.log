{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015RnV7LETzrULjEFUZFvK4H","type":"tool_result","content":"     1→import { Application } from \"pixi.js\";\n     2→import { createGrid } from \"./grid\";\n     3→import { Connection, setupConnections } from \"./connections\";\n     4→import { isSubmitted, getStoredConnections, submitConnections } from \"./submit\";\n     5→\n     6→const app = new Application();\n     7→\n     8→await app.init({\n     9→  background: \"#1a1a2e\",\n    10→  resizeTo: window,\n    11→  antialias: true,\n    12→  resolution: window.devicePixelRatio || 1,\n    13→  autoDensity: true,\n    14→});\n    15→\n    16→document.body.appendChild(app.canvas);\n    17→\n    18→const boxes = createGrid(app);\n    19→const manager = setupConnections(app, boxes);\n    20→\n    21→// --- UI elements ---\n    22→const resetBtn = document.getElementById(\"reset-btn\") as HTMLButtonElement;\n    23→const undoToast = document.getElementById(\"undo-toast\") as HTMLDivElement;\n    24→const submitBtn = document.getElementById(\"submit-btn\") as HTMLButtonElement;\n    25→const resultsBtn = document.getElementById(\"results-btn\") as HTMLButtonElement;\n    26→const submitError = document.getElementById(\"submit-error\") as HTMLDivElement;\n    27→\n    28→let submitted = isSubmitted();\n    29→\n    30→// Restore connections from localStorage if previously submitted\n    31→if (submitted) {\n    32→  const stored = getStoredConnections();\n    33→  manager.connections.push(...stored);\n    34→  manager.redraw();\n    35→  resultsBtn.style.display = \"\";\n    36→}\n    37→let undoBackup: Connection[] | null = null;\n    38→let undoTimer: ReturnType<typeof setTimeout> | null = null;\n    39→\n    40→function updateButtonVisibility() {\n    41→  if (submitted) {\n    42→    resetBtn.style.display = \"none\";\n    43→    submitBtn.style.display = \"none\";\n    44→    return;\n    45→  }\n    46→  const hasConnections = manager.connections.length > 0;\n    47→  resetBtn.style.display = hasConnections ? \"\" : \"none\";\n    48→  submitBtn.style.display = hasConnections ? \"\" : \"none\";\n    49→}\n    50→\n    51→// Poll visibility cheaply via animation frame (connections change from pointer events)\n    52→function tick() {\n    53→  updateButtonVisibility();\n    54→  requestAnimationFrame(tick);\n    55→}\n    56→requestAnimationFrame(tick);\n    57→\n    58→// --- Reset button + undo toast ---\n    59→resetBtn.addEventListener(\"click\", () => {\n    60→  const removed = manager.resetAll();\n    61→  if (removed.length === 0) return;\n    62→\n    63→  undoBackup = removed;\n    64→  undoToast.style.display = \"\";\n    65→  resetBtn.style.display = \"none\";\n    66→  submitBtn.style.display = \"none\";\n    67→\n    68→  if (undoTimer) clearTimeout(undoTimer);\n    69→  undoTimer = setTimeout(() => {\n    70→    undoBackup = null;\n    71→    undoToast.style.display = \"none\";\n    72→    undoTimer = null;\n    73→  }, 3000);\n    74→});\n    75→\n    76→undoToast.addEventListener(\"click\", () => {\n    77→  if (!undoBackup) return;\n    78→  manager.connections.push(...undoBackup);\n    79→  manager.redraw();\n    80→  undoBackup = null;\n    81→  undoToast.style.display = \"none\";\n    82→  if (undoTimer) {\n    83→    clearTimeout(undoTimer);\n    84→    undoTimer = null;\n    85→  }\n    86→});\n    87→\n    88→// --- Submit button ---\n    89→submitBtn.addEventListener(\"click\", async () => {\n    90→  if (submitted || manager.connections.length === 0) return;\n    91→\n    92→  submitBtn.disabled = true;\n    93→  submitBtn.textContent = \"Sender...\";\n    94→  submitError.style.display = \"none\";\n    95→\n    96→  try {\n    97→    await submitConnections(manager.connections);\n    98→    submitted = true;\n    99→    submitBtn.style.display = \"none\";\n   100→    resetBtn.style.display = \"none\";\n   101→    resultsBtn.style.display = \"\";\n   102→  } catch (err) {\n   103→    submitBtn.disabled = false;\n   104→    submitBtn.textContent = \"Send\";\n   105→    submitError.textContent = \"Noget gik galt — prøv igen\";\n   106→    submitError.style.display = \"\";\n   107→    setTimeout(() => {\n   108→      submitError.style.display = \"none\";\n   109→    }, 4000);\n   110→  }\n   111→});\n   112→"}]},"parent_tool_use_id":null,"session_id":"7e877d12-cc08-4522-9c52-641e0b04ab62","uuid":"ad6bc4b6-c817-4b6f-9a2b-3f099284a2df","tool_use_result":{"type":"text","file":{"filePath":"/Users/jstoone/Sites/linjer/src/main.ts","content":"import { Application } from \"pixi.js\";\nimport { createGrid } from \"./grid\";\nimport { Connection, setupConnections } from \"./connections\";\nimport { isSubmitted, getStoredConnections, submitConnections } from \"./submit\";\n\nconst app = new Application();\n\nawait app.init({\n  background: \"#1a1a2e\",\n  resizeTo: window,\n  antialias: true,\n  resolution: window.devicePixelRatio || 1,\n  autoDensity: true,\n});\n\ndocument.body.appendChild(app.canvas);\n\nconst boxes = createGrid(app);\nconst manager = setupConnections(app, boxes);\n\n// --- UI elements ---\nconst resetBtn = document.getElementById(\"reset-btn\") as HTMLButtonElement;\nconst undoToast = document.getElementById(\"undo-toast\") as HTMLDivElement;\nconst submitBtn = document.getElementById(\"submit-btn\") as HTMLButtonElement;\nconst resultsBtn = document.getElementById(\"results-btn\") as HTMLButtonElement;\nconst submitError = document.getElementById(\"submit-error\") as HTMLDivElement;\n\nlet submitted = isSubmitted();\n\n// Restore connections from localStorage if previously submitted\nif (submitted) {\n  const stored = getStoredConnections();\n  manager.connections.push(...stored);\n  manager.redraw();\n  resultsBtn.style.display = \"\";\n}\nlet undoBackup: Connection[] | null = null;\nlet undoTimer: ReturnType<typeof setTimeout> | null = null;\n\nfunction updateButtonVisibility() {\n  if (submitted) {\n    resetBtn.style.display = \"none\";\n    submitBtn.style.display = \"none\";\n    return;\n  }\n  const hasConnections = manager.connections.length > 0;\n  resetBtn.style.display = hasConnections ? \"\" : \"none\";\n  submitBtn.style.display = hasConnections ? \"\" : \"none\";\n}\n\n// Poll visibility cheaply via animation frame (connections change from pointer events)\nfunction tick() {\n  updateButtonVisibility();\n  requestAnimationFrame(tick);\n}\nrequestAnimationFrame(tick);\n\n// --- Reset button + undo toast ---\nresetBtn.addEventListener(\"click\", () => {\n  const removed = manager.resetAll();\n  if (removed.length === 0) return;\n\n  undoBackup = removed;\n  undoToast.style.display = \"\";\n  resetBtn.style.display = \"none\";\n  submitBtn.style.display = \"none\";\n\n  if (undoTimer) clearTimeout(undoTimer);\n  undoTimer = setTimeout(() => {\n    undoBackup = null;\n    undoToast.style.display = \"none\";\n    undoTimer = null;\n  }, 3000);\n});\n\nundoToast.addEventListener(\"click\", () => {\n  if (!undoBackup) return;\n  manager.connections.push(...undoBackup);\n  manager.redraw();\n  undoBackup = null;\n  undoToast.style.display = \"none\";\n  if (undoTimer) {\n    clearTimeout(undoTimer);\n    undoTimer = null;\n  }\n});\n\n// --- Submit button ---\nsubmitBtn.addEventListener(\"click\", async () => {\n  if (submitted || manager.connections.length === 0) return;\n\n  submitBtn.disabled = true;\n  submitBtn.textContent = \"Sender...\";\n  submitError.style.display = \"none\";\n\n  try {\n    await submitConnections(manager.connections);\n    submitted = true;\n    submitBtn.style.display = \"none\";\n    resetBtn.style.display = \"none\";\n    resultsBtn.style.display = \"\";\n  } catch (err) {\n    submitBtn.disabled = false;\n    submitBtn.textContent = \"Send\";\n    submitError.textContent = \"Noget gik galt — prøv igen\";\n    submitError.style.display = \"\";\n    setTimeout(() => {\n      submitError.style.display = \"none\";\n    }, 4000);\n  }\n});\n","numLines":112,"startLine":1,"totalLines":112}}}
