lStorage.setItem(SUBMITTED_KEY, \"true\");\n  localStorage.setItem(CONNECTIONS_KEY, JSON.stringify(connections));\n}\n","structuredPatch":[{"oldStart":18,"oldLines":6,"newStart":18,"newLines":16,"lines":["   return localStorage.getItem(SUBMITTED_KEY) === \"true\";"," }"," ","+export function getStoredConnections(): Connection[] {","+  const raw = localStorage.getItem(CONNECTIONS_KEY);","+  if (!raw) return [];","+  try {","+    return JSON.parse(raw) as Connection[];","+  } catch {","+    return [];","+  }","+}","+"," /**","  * Submit connections to Supabase.","  * Box indices are 0-based internally — we store 1-based in the DB."]}],"userModified":false,"replaceAll":false}}
