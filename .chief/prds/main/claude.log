{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01S1h2rbbkRxMfxG5wbHn5jm","type":"tool_result","content":"     1→import { supabase } from \"./supabase\";\n     2→import type { Connection } from \"./connections\";\n     3→\n     4→const SESSION_KEY = \"linjer_session_id\";\n     5→const SUBMITTED_KEY = \"linjer_submitted\";\n     6→const CONNECTIONS_KEY = \"linjer_connections\";\n     7→\n     8→function getSessionId(): string {\n     9→  let id = localStorage.getItem(SESSION_KEY);\n    10→  if (!id) {\n    11→    id = crypto.randomUUID();\n    12→    localStorage.setItem(SESSION_KEY, id);\n    13→  }\n    14→  return id;\n    15→}\n    16→\n    17→export function isSubmitted(): boolean {\n    18→  return localStorage.getItem(SUBMITTED_KEY) === \"true\";\n    19→}\n    20→\n    21→/**\n    22→ * Submit connections to Supabase.\n    23→ * Box indices are 0-based internally — we store 1-based in the DB.\n    24→ */\n    25→export async function submitConnections(\n    26→  connections: Connection[],\n    27→): Promise<void> {\n    28→  const sessionId = getSessionId();\n    29→\n    30→  const rows = connections.map((c) => ({\n    31→    session_id: sessionId,\n    32→    source_box: c.source + 1,\n    33→    target_box: c.target + 1,\n    34→  }));\n    35→\n    36→  const { error } = await supabase.from(\"connections\").insert(rows);\n    37→\n    38→  if (error) {\n    39→    throw new Error(error.message);\n    40→  }\n    41→\n    42→  // Mark as submitted in localStorage\n    43→  localStorage.setItem(SUBMITTED_KEY, \"true\");\n    44→  localStorage.setItem(CONNECTIONS_KEY, JSON.stringify(connections));\n    45→}\n    46→"}]},"parent_tool_use_id":null,"session_id":"55454d52-f8b7-4bbb-90ac-b6b8c0995947","uuid":"0a1a8ed8-07bf-4f1a-b36c-5c6eddd61545","tool_use_result":{"type":"text","file":{"filePath":"/Users/jstoone/Sites/linjer/src/submit.ts","content":"import { supabase } from \"./supabase\";\nimport type { Connection } from \"./connections\";\n\nconst SESSION_KEY = \"linjer_session_id\";\nconst SUBMITTED_KEY = \"linjer_submitted\";\nconst CONNECTIONS_KEY = \"linjer_connections\";\n\nfunction getSessionId(): string {\n  let id = localStorage.getItem(SESSION_KEY);\n  if (!id) {\n    id = crypto.randomUUID();\n    localStorage.setItem(SESSION_KEY, id);\n  }\n  return id;\n}\n\nexport function isSubmitted(): boolean {\n  return localStorage.getItem(SUBMITTED_KEY) === \"true\";\n}\n\n/**\n * Submit connections to Supabase.\n * Box indices are 0-based internally — we store 1-based in the DB.\n */\nexport async function submitConnections(\n  connections: Connection[],\n): Promise<void> {\n  const sessionId = getSessionId();\n\n  const rows = connections.map((c) => ({\n    session_id: sessionId,\n    source_box: c.source + 1,\n    target_box: c.target + 1,\n  }));\n\n  const { error } = await supabase.from(\"connections\").insert(rows);\n\n  if (error) {\n    throw new Error(error.message);\n  }\n\n  // Mark as submitted in localStorage\n  localStorage.setItem(SUBMITTED_KEY, \"true\");\n  localStorage.setItem(CONNECTIONS_KEY, JSON.stringify(connections));\n}\n","numLines":46,"startLine":1,"totalLines":46}}}
