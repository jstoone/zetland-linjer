{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01USFX2EncURy5tEGwq9Xf12","type":"tool_result","content":"     1→import { Application } from \"pixi.js\";\n     2→import { createGrid } from \"./grid\";\n     3→import { Connection, setupConnections } from \"./connections\";\n     4→import { isSubmitted, submitConnections } from \"./submit\";\n     5→\n     6→const app = new Application();\n     7→\n     8→await app.init({\n     9→  background: \"#1a1a2e\",\n    10→  resizeTo: window,\n    11→  antialias: true,\n    12→  resolution: window.devicePixelRatio || 1,\n    13→  autoDensity: true,\n    14→});\n    15→\n    16→document.body.appendChild(app.canvas);\n    17→\n    18→const boxes = createGrid(app);\n    19→const manager = setupConnections(app, boxes);\n    20→\n    21→// --- UI elements ---\n    22→const resetBtn = document.getElementById(\"reset-btn\") as HTMLButtonElement;\n    23→const undoToast = document.getElementById(\"undo-toast\") as HTMLDivElement;\n    24→const submitBtn = document.getElementById(\"submit-btn\") as HTMLButtonElement;\n    25→const submitError = document.getElementById(\"submit-error\") as HTMLDivElement;\n    26→\n    27→let submitted = isSubmitted();\n    28→let undoBackup: Connection[] | null = null;\n    29→let undoTimer: ReturnType<typeof setTimeout> | null = null;\n    30→\n    31→function updateButtonVisibility() {\n    32→  if (submitted) {\n    33→    resetBtn.style.display = \"none\";\n    34→    submitBtn.style.display = \"none\";\n    35→    return;\n    36→  }\n    37→  const hasConnections = manager.connections.length > 0;\n    38→  resetBtn.style.display = hasConnections ? \"\" : \"none\";\n    39→  submitBtn.style.display = hasConnections ? \"\" : \"none\";\n    40→}\n    41→\n    42→// Poll visibility cheaply via animation frame (connections change from pointer events)\n    43→function tick() {\n    44→  updateButtonVisibility();\n    45→  requestAnimationFrame(tick);\n    46→}\n    47→requestAnimationFrame(tick);\n    48→\n    49→// --- Reset button + undo toast ---\n    50→resetBtn.addEventListener(\"click\", () => {\n    51→  const removed = manager.resetAll();\n    52→  if (removed.length === 0) return;\n    53→\n    54→  undoBackup = removed;\n    55→  undoToast.style.display = \"\";\n    56→  resetBtn.style.display = \"none\";\n    57→  submitBtn.style.display = \"none\";\n    58→\n    59→  if (undoTimer) clearTimeout(undoTimer);\n    60→  undoTimer = setTimeout(() => {\n    61→    undoBackup = null;\n    62→    undoToast.style.display = \"none\";\n    63→    undoTimer = null;\n    64→  }, 3000);\n    65→});\n    66→\n    67→undoToast.addEventListener(\"click\", () => {\n    68→  if (!undoBackup) return;\n    69→  manager.connections.push(...undoBackup);\n    70→  manager.redraw();\n    71→  undoBackup = null;\n    72→  undoToast.style.display = \"none\";\n    73→  if (undoTimer) {\n    74→    clearTimeout(undoTimer);\n    75→    undoTimer = null;\n    76→  }\n    77→});\n    78→\n    79→// --- Submit button ---\n    80→submitBtn.addEventListener(\"click\", async () => {\n    81→  if (submitted || manager.connections.length === 0) return;\n    82→\n    83→  submitBtn.disabled = true;\n    84→  submitBtn.textContent = \"Sender...\";\n    85→  submitError.style.display = \"none\";\n    86→\n    87→  try {\n    88→    await submitConnections(manager.connections);\n    89→    submitted = true;\n    90→    submitBtn.style.display = \"none\";\n    91→    resetBtn.style.display = \"none\";\n    92→  } catch (err) {\n    93→    submitBtn.disabled = false;\n    94→    submitBtn.textContent = \"Send\";\n    95→    submitError.textContent = \"Noget gik galt — prøv igen\";\n    96→    submitError.style.display = \"\";\n    97→    setTimeout(() => {\n    98→      submitError.style.display = \"none\";\n    99→    }, 4000);\n   100→  }\n   101→});\n   102→"}]},"parent_tool_use_id":null,"session_id":"55454d52-f8b7-4bbb-90ac-b6b8c0995947","uuid":"b891c157-f49b-439e-8739-a239f80b2421","tool_use_result":{"type":"text","file":{"filePath":"/Users/jstoone/Sites/linjer/src/main.ts","content":"import { Application } from \"pixi.js\";\nimport { createGrid } from \"./grid\";\nimport { Connection, setupConnections } from \"./connections\";\nimport { isSubmitted, submitConnections } from \"./submit\";\n\nconst app = new Application();\n\nawait app.init({\n  background: \"#1a1a2e\",\n  resizeTo: window,\n  antialias: true,\n  resolution: window.devicePixelRatio || 1,\n  autoDensity: true,\n});\n\ndocument.body.appendChild(app.canvas);\n\nconst boxes = createGrid(app);\nconst manager = setupConnections(app, boxes);\n\n// --- UI elements ---\nconst resetBtn = document.getElementById(\"reset-btn\") as HTMLButtonElement;\nconst undoToast = document.getElementById(\"undo-toast\") as HTMLDivElement;\nconst submitBtn = document.getElementById(\"submit-btn\") as HTMLButtonElement;\nconst submitError = document.getElementById(\"submit-error\") as HTMLDivElement;\n\nlet submitted = isSubmitted();\nlet undoBackup: Connection[] | null = null;\nlet undoTimer: ReturnType<typeof setTimeout> | null = null;\n\nfunction updateButtonVisibility() {\n  if (submitted) {\n    resetBtn.style.display = \"none\";\n    submitBtn.style.display = \"none\";\n    return;\n  }\n  const hasConnections = manager.connections.length > 0;\n  resetBtn.style.display = hasConnections ? \"\" : \"none\";\n  submitBtn.style.display = hasConnections ? \"\" : \"none\";\n}\n\n// Poll visibility cheaply via animation frame (connections change from pointer events)\nfunction tick() {\n  updateButtonVisibility();\n  requestAnimationFrame(tick);\n}\nrequestAnimationFrame(tick);\n\n// --- Reset button + undo toast ---\nresetBtn.addEventListener(\"click\", () => {\n  const removed = manager.resetAll();\n  if (removed.length === 0) return;\n\n  undoBackup = removed;\n  undoToast.style.display = \"\";\n  resetBtn.style.display = \"none\";\n  submitBtn.style.display = \"none\";\n\n  if (undoTimer) clearTimeout(undoTimer);\n  undoTimer = setTimeout(() => {\n    undoBackup = null;\n    undoToast.style.display = \"none\";\n    undoTimer = null;\n  }, 3000);\n});\n\nundoToast.addEventListener(\"click\", () => {\n  if (!undoBackup) return;\n  manager.connections.push(...undoBackup);\n  manager.redraw();\n  undoBackup = null;\n  undoToast.style.display = \"none\";\n  if (undoTimer) {\n    clearTimeout(undoTimer);\n    undoTimer = null;\n  }\n});\n\n// --- Submit button ---\nsubmitBtn.addEventListener(\"click\", async () => {\n  if (submitted || manager.connections.length === 0) return;\n\n  submitBtn.disabled = true;\n  submitBtn.textContent = \"Sender...\";\n  submitError.style.display = \"none\";\n\n  try {\n    await submitConnections(manager.connections);\n    submitted = true;\n    submitBtn.style.display = \"none\";\n    resetBtn.style.display = \"none\";\n  } catch (err) {\n    submitBtn.disabled = false;\n    submitBtn.textContent = \"Send\";\n    submitError.textContent = \"Noget gik galt — prøv igen\";\n    submitError.style.display = \"\";\n    setTimeout(() => {\n      submitError.style.display = \"none\";\n    }, 4000);\n  }\n});\n","numLines":102,"startLine":1,"totalLines":102}}}
