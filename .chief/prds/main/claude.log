{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0139XjXQZYoY1oDmKjDkXrvj","type":"tool_result","content":"     1→import {\n     2→  Application,\n     3→  Graphics,\n     4→  FederatedPointerEvent,\n     5→  Rectangle,\n     6→} from \"pixi.js\";\n     7→import { BoxInfo } from \"./grid\";\n     8→\n     9→export interface Connection {\n    10→  source: number;\n    11→  target: number;\n    12→}\n    13→\n    14→const LINE_COLOR = 0xe94560;\n    15→const PREVIEW_COLOR = 0x53c28b;\n    16→const LINE_WIDTH = 2.5;\n    17→const PREVIEW_WIDTH = 2;\n    18→const ARROW_SIZE = 8;\n    19→const CURVE_OFFSET_RATIO = 0.15;\n    20→\n    21→export interface ConnectionManager {\n    22→  connections: Connection[];\n    23→  redraw: () => void;\n    24→}\n    25→\n    26→/**\n    27→ * Sets up drag-to-connect interaction on the box grid.\n    28→ * Returns a ConnectionManager for use by future features (tap-tap, remove, reset).\n    29→ */\n    30→export function setupConnections(\n    31→  app: Application,\n    32→  boxes: BoxInfo[],\n    33→): ConnectionManager {\n    34→  const connections: Connection[] = [];\n    35→  const linesLayer = new Graphics();\n    36→  const previewLayer = new Graphics();\n    37→  app.stage.addChild(linesLayer);\n    38→  app.stage.addChild(previewLayer);\n    39→\n    40→  let dragSource: BoxInfo | null = null;\n    41→  let pointerX = 0;\n    42→  let pointerY = 0;\n    43→\n    44→  // Make each box interactive\n    45→  for (const box of boxes) {\n    46→    box.container.eventMode = \"static\";\n    47→    box.container.cursor = \"pointer\";\n    48→    box.container.hitArea = new Rectangle(0, 0, box.w, box.h);\n    49→    box.container.on(\"pointerdown\", (e: FederatedPointerEvent) => {\n    50→      dragSource = box;\n    51→      pointerX = e.global.x;\n    52→      pointerY = e.global.y;\n    53→    });\n    54→  }\n    55→\n    56→  // Stage-level handlers for move and up\n    57→  app.stage.eventMode = \"static\";\n    58→  app.stage.hitArea = app.screen;\n    59→\n    60→  app.stage.on(\"pointermove\", (e: FederatedPointerEvent) => {\n    61→    if (!dragSource) return;\n    62→    pointerX = e.global.x;\n    63→    pointerY = e.global.y;\n    64→    drawPreview();\n    65→  });\n    66→\n    67→  const endDrag = (e: FederatedPointerEvent) => {\n    68→    if (!dragSource) return;\n    69→    const target = hitTest(e.global.x, e.global.y, boxes);\n    70→    if (target && target.index !== dragSource.index) {\n    71→      connections.push({ source: dragSource.index, target: target.index });\n    72→      redraw();\n    73→    }\n    74→    dragSource = null;\n    75→    previewLayer.clear();\n    76→  };\n    77→\n    78→  app.stage.on(\"pointerup\", endDrag);\n    79→  app.stage.on(\"pointerupoutside\", endDrag);\n    80→  app.stage.on(\"pointercancel\", () => {\n    81→    dragSource = null;\n    82→    previewLayer.clear();\n    83→  });\n    84→\n    85→  function drawPreview() {\n    86→    previewLayer.clear();\n    87→    if (!dragSource) return;\n    88→\n    89→    const sx = dragSource.cx;\n    90→    const sy = dragSource.cy;\n    91→    const dx = pointerX - sx;\n    92→    const dy = pointerY - sy;\n    93→    const dist = Math.sqrt(dx * dx + dy * dy);\n    94→    if (dist < 5) return;\n    95→\n    96→    const perpX = -dy / dist;\n    97→    const perpY = dx / dist;\n    98→    const offset = dist * 0.1;\n    99→    const cpX = (sx + pointerX) / 2 + perpX * offset;\n   100→    const cpY = (sy + pointerY) / 2 + perpY * offset;\n   101→\n   102→    previewLayer.moveTo(sx, sy);\n   103→    previewLayer.quadraticCurveTo(cpX, cpY, pointerX, pointerY);\n   104→    previewLayer.stroke({\n   105→      width: PREVIEW_WIDTH,\n   106→      color: PREVIEW_COLOR,\n   107→      alpha: 0.6,\n   108→    });\n   109→  }\n   110→\n   111→  function redraw() {\n   112→    linesLayer.clear();\n   113→    for (const conn of connections) {\n   114→      const source = boxes[conn.source]!;\n   115→      const target = boxes[conn.target]!;\n   116→      drawConnection(linesLayer, source, target);\n   117→    }\n   118→  }\n   119→\n   120→  return { connections, redraw };\n   121→}\n   122→\n   123→function drawConnection(g: Graphics, source: BoxInfo, target: BoxInfo) {\n   124→  const dx = target.cx - source.cx;\n   125→  const dy = target.cy - source.cy;\n   126→  const dist = Math.sqrt(dx * dx + dy * dy);\n   127→  if (dist < 1) return;\n   128→\n   129→  // Edge intersection points — line starts/ends at box boundaries\n   130→  const start = boxEdge(source, target.cx, target.cy);\n   131→  const end = boxEdge(target, source.cx, source.cy);\n   132→\n   133→  // Perpendicular offset for gentle bezier curve\n   134→  const perpX = -dy / dist;\n   135→  const perpY = dx / dist;\n   136→  const offset = dist * CURVE_OFFSET_RATIO;\n   137→\n   138→  const midX = (source.cx + target.cx) / 2;\n   139→  const midY = (source.cy + target.cy) / 2;\n   140→  const cpX = midX + perpX * offset;\n   141→  const cpY = midY + perpY * offset;\n   142→\n   143→  // Draw curve\n   144→  g.moveTo(start.x, start.y);\n   145→  g.quadraticCurveTo(cpX, cpY, end.x, end.y);\n   146→  g.stroke({ width: LINE_WIDTH, color: LINE_COLOR });\n   147→\n   148→  // Arrowhead — tangent at endpoint is direction from CP to endpoint\n   149→  const tdx = end.x - cpX;\n   150→  const tdy = end.y - cpY;\n   151→  const tLen = Math.sqrt(tdx * tdx + tdy * tdy);\n   152→  if (tLen < 1) return;\n   153→\n   154→  const ux = tdx / tLen;\n   155→  const uy = tdy / tLen;\n   156→\n   157→  g.moveTo(end.x, end.y);\n   158→  g.lineTo(\n   159→    end.x - ux * ARROW_SIZE + uy * ARROW_SIZE * 0.4,\n   160→    end.y - uy * ARROW_SIZE - ux * ARROW_SIZE * 0.4,\n   161→  );\n   162→  g.lineTo(\n   163→    end.x - ux * ARROW_SIZE - uy * ARROW_SIZE * 0.4,\n   164→    end.y - uy * ARROW_SIZE + ux * ARROW_SIZE * 0.4,\n   165→  );\n   166→  g.closePath();\n   167→  g.fill({ color: LINE_COLOR });\n   168→}\n   169→\n   170→/** Computes where a ray from the box center toward (toX, toY) exits the box boundary. */\n   171→function boxEdge(\n   172→  box: BoxInfo,\n   173→  toX: number,\n   174→  toY: number,\n   175→): { x: number; y: number } {\n   176→  const dx = toX - box.cx;\n   177→  const dy = toY - box.cy;\n   178→  if (dx === 0 && dy === 0) return { x: box.cx, y: box.cy };\n   179→\n   180→  const halfW = box.w / 2;\n   181→  const halfH = box.h / 2;\n   182→  const scale =\n   183→    Math.abs(dx) / halfW > Math.abs(dy) / halfH\n   184→      ? halfW / Math.abs(dx)\n   185→      : halfH / Math.abs(dy);\n   186→\n   187→  return { x: box.cx + dx * scale, y: box.cy + dy * scale };\n   188→}\n   189→\n   190→function hitTest(x: number, y: number, boxes: BoxInfo[]): BoxInfo | null {\n   191→  for (const box of boxes) {\n   192→    const left = box.cx - box.w / 2;\n   193→    const right = box.cx + box.w / 2;\n   194→    const top = box.cy - box.h / 2;\n   195→    const bottom = box.cy + box.h / 2;\n   196→    if (x >= left && x <= right && y >= top && y <= bottom) {\n   197→      return box;\n   198→    }\n   199→  }\n   200→  return null;\n   201→}\n   202→"}]},"parent_tool_use_id":null,"session_id":"9148dbc1-4780-49bf-adf6-0e49414c1c59","uuid":"57b17112-bf98-48ab-8984-c198a22596a9","tool_use_result":{"type":"text","file":{"filePath":"/Users/jstoone/Sites/linjer/src/connections.ts","content":"import {\n  Application,\n  Graphics,\n  FederatedPointerEvent,\n  Rectangle,\n} from \"pixi.js\";\nimport { BoxInfo } from \"./grid\";\n\nexport interface Connection {\n  source: number;\n  target: number;\n}\n\nconst LINE_COLOR = 0xe94560;\nconst PREVIEW_COLOR = 0x53c28b;\nconst LINE_WIDTH = 2.5;\nconst PREVIEW_WIDTH = 2;\nconst ARROW_SIZE = 8;\nconst CURVE_OFFSET_RATIO = 0.15;\n\nexport interface ConnectionManager {\n  connections: Connection[];\n  redraw: () => void;\n}\n\n/**\n * Sets up drag-to-connect interaction on the box grid.\n * Returns a ConnectionManager for use by future features (tap-tap, remove, reset).\n */\nexport function setupConnections(\n  app: Application,\n  boxes: BoxInfo[],\n): ConnectionManager {\n  const connections: Connection[] = [];\n  const linesLayer = new Graphics();\n  const previewLayer = new Graphics();\n  app.stage.addChild(linesLayer);\n  app.stage.addChild(previewLayer);\n\n  let dragSource: BoxInfo | null = null;\n  let pointerX = 0;\n  let pointerY = 0;\n\n  // Make each box interactive\n  for (const box of boxes) {\n    box.container.eventMode = \"static\";\n    box.container.cursor = \"pointer\";\n    box.container.hitArea = new Rectangle(0, 0, box.w, box.h);\n    box.container.on(\"pointerdown\", (e: FederatedPointerEvent) => {\n      dragSource = box;\n      pointerX = e.global.x;\n      pointerY = e.global.y;\n    });\n  }\n\n  // Stage-level handlers for move and up\n  app.stage.eventMode = \"static\";\n  app.stage.hitArea = app.screen;\n\n  app.stage.on(\"pointermove\", (e: FederatedPointerEvent) => {\n    if (!dragSource) return;\n    pointerX = e.global.x;\n    pointerY = e.global.y;\n    drawPreview();\n  });\n\n  const endDrag = (e: FederatedPointerEvent) => {\n    if (!dragSource) return;\n    const target = hitTest(e.global.x, e.global.y, boxes);\n    if (target && target.index !== dragSource.index) {\n      connections.push({ source: dragSource.index, target: target.index });\n      redraw();\n    }\n    dragSource = null;\n    previewLayer.clear();\n  };\n\n  app.stage.on(\"pointerup\", endDrag);\n  app.stage.on(\"pointerupoutside\", endDrag);\n  app.stage.on(\"pointercancel\", () => {\n    dragSource = null;\n    previewLayer.clear();\n  });\n\n  function drawPreview() {\n    previewLayer.clear();\n    if (!dragSource) return;\n\n    const sx = dragSource.cx;\n    const sy = dragSource.cy;\n    const dx = pointerX - sx;\n    const dy = pointerY - sy;\n    const dist = Math.sqrt(dx * dx + dy * dy);\n    if (dist < 5) return;\n\n    const perpX = -dy / dist;\n    const perpY = dx / dist;\n    const offset = dist * 0.1;\n    const cpX = (sx + pointerX) / 2 + perpX * offset;\n    const cpY = (sy + pointerY) / 2 + perpY * offset;\n\n    previewLayer.moveTo(sx, sy);\n    previewLayer.quadraticCurveTo(cpX, cpY, pointerX, pointerY);\n    previewLayer.stroke({\n      width: PREVIEW_WIDTH,\n      color: PREVIEW_COLOR,\n      alpha: 0.6,\n    });\n  }\n\n  function redraw() {\n    linesLayer.clear();\n    for (const conn of connections) {\n      const source = boxes[conn.source]!;\n      const target = boxes[conn.target]!;\n      drawConnection(linesLayer, source, target);\n    }\n  }\n\n  return { connections, redraw };\n}\n\nfunction drawConnection(g: Graphics, source: BoxInfo, target: BoxInfo) {\n  const dx = target.cx - source.cx;\n  const dy = target.cy - source.cy;\n  const dist = Math.sqrt(dx * dx + dy * dy);\n  if (dist < 1) return;\n\n  // Edge intersection points — line starts/ends at box boundaries\n  const start = boxEdge(source, target.cx, target.cy);\n  const end = boxEdge(target, source.cx, source.cy);\n\n  // Perpendicular offset for gentle bezier curve\n  const perpX = -dy / dist;\n  const perpY = dx / dist;\n  const offset = dist * CURVE_OFFSET_RATIO;\n\n  const midX = (source.cx + target.cx) / 2;\n  const midY = (source.cy + target.cy) / 2;\n  const cpX = midX + perpX * offset;\n  const cpY = midY + perpY * offset;\n\n  // Draw curve\n  g.moveTo(start.x, start.y);\n  g.quadraticCurveTo(cpX, cpY, end.x, end.y);\n  g.stroke({ width: LINE_WIDTH, color: LINE_COLOR });\n\n  // Arrowhead — tangent at endpoint is direction from CP to endpoint\n  const tdx = end.x - cpX;\n  const tdy = end.y - cpY;\n  const tLen = Math.sqrt(tdx * tdx + tdy * tdy);\n  if (tLen < 1) return;\n\n  const ux = tdx / tLen;\n  const uy = tdy / tLen;\n\n  g.moveTo(end.x, end.y);\n  g.lineTo(\n    end.x - ux * ARROW_SIZE + uy * ARROW_SIZE * 0.4,\n    end.y - uy * ARROW_SIZE - ux * ARROW_SIZE * 0.4,\n  );\n  g.lineTo(\n    end.x - ux * ARROW_SIZE - uy * ARROW_SIZE * 0.4,\n    end.y - uy * ARROW_SIZE + ux * ARROW_SIZE * 0.4,\n  );\n  g.closePath();\n  g.fill({ color: LINE_COLOR });\n}\n\n/** Computes where a ray from the box center toward (toX, toY) exits the box boundary. */\nfunction boxEdge(\n  box: BoxInfo,\n  toX: number,\n  toY: number,\n): { x: number; y: number } {\n  const dx = toX - box.cx;\n  const dy = toY - box.cy;\n  if (dx === 0 && dy === 0) return { x: box.cx, y: box.cy };\n\n  const halfW = box.w / 2;\n  const halfH = box.h / 2;\n  const scale =\n    Math.abs(dx) / halfW > Math.abs(dy) / halfH\n      ? halfW / Math.abs(dx)\n      : halfH / Math.abs(dy);\n\n  return { x: box.cx + dx * scale, y: box.cy + dy * scale };\n}\n\nfunction hitTest(x: number, y: number, boxes: BoxInfo[]): BoxInfo | null {\n  for (const box of boxes) {\n    const left = box.cx - box.w / 2;\n    const right = box.cx + box.w / 2;\n    const top = box.cy - box.h / 2;\n    const bottom = box.cy + box.h / 2;\n    if (x >= left && x <= right && y >= top && y <= bottom) {\n      return box;\n    }\n  }\n  return null;\n}\n","numLines":202,"startLine":1,"totalLines":202}}}
