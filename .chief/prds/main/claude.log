{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TQSaW3XtK2HgiJXLeH2FM7","type":"tool_result","content":"     1→import {\n     2→  Application,\n     3→  Graphics,\n     4→  FederatedPointerEvent,\n     5→  Rectangle,\n     6→} from \"pixi.js\";\n     7→import { BoxInfo } from \"./grid\";\n     8→\n     9→export interface Connection {\n    10→  source: number;\n    11→  target: number;\n    12→}\n    13→\n    14→const LINE_COLOR = 0xe94560;\n    15→const PREVIEW_COLOR = 0x53c28b;\n    16→const SELECTED_COLOR = 0x53c28b;\n    17→const LINE_WIDTH = 2.5;\n    18→const PREVIEW_WIDTH = 2;\n    19→const ARROW_SIZE = 8;\n    20→const CURVE_OFFSET_RATIO = 0.15;\n    21→const TAP_THRESHOLD = 10;\n    22→const HIGHLIGHT_RADIUS = 10;\n    23→const LINE_HIT_THRESHOLD = 20;\n    24→const FADE_SPEED = 0.04;\n    25→\n    26→export interface ConnectionManager {\n    27→  connections: Connection[];\n    28→  redraw: () => void;\n    29→  resetAll: () => Connection[];\n    30→}\n    31→\n    32→/**\n    33→ * Sets up drag-to-connect interaction on the box grid.\n    34→ * Returns a ConnectionManager for use by future features (tap-tap, remove, reset).\n    35→ */\n    36→export function setupConnections(\n    37→  app: Application,\n    38→  boxes: BoxInfo[],\n    39→): ConnectionManager {\n    40→  const connections: Connection[] = [];\n    41→  const highlightLayer = new Graphics();\n    42→  const linesLayer = new Graphics();\n    43→  const previewLayer = new Graphics();\n    44→  app.stage.addChild(highlightLayer);\n    45→  app.stage.addChild(linesLayer);\n    46→  app.stage.addChild(previewLayer);\n    47→\n    48→  let dragSource: BoxInfo | null = null;\n    49→  let pointerX = 0;\n    50→  let pointerY = 0;\n    51→  let dragStartX = 0;\n    52→  let dragStartY = 0;\n    53→  let selectedBoxIndex: number | null = null;\n    54→\n    55→  function toggle(source: number, target: number) {\n    56→    const idx = connections.findIndex(\n    57→      c => c.source === source && c.target === target\n    58→    );\n    59→    if (idx >= 0) {\n    60→      animateRemoval(app, boxes, connections.splice(idx, 1)[0]!);\n    61→    } else {\n    62→      connections.push({ source, target });\n    63→    }\n    64→  }\n    65→\n    66→  // Make each box interactive\n    67→  for (const box of boxes) {\n    68→    box.container.eventMode = \"static\";\n    69→    box.container.cursor = \"pointer\";\n    70→    box.container.hitArea = new Rectangle(0, 0, box.w, box.h);\n    71→    box.container.on(\"pointerdown\", (e: FederatedPointerEvent) => {\n    72→      dragSource = box;\n    73→      dragStartX = e.global.x;\n    74→      dragStartY = e.global.y;\n    75→      pointerX = e.global.x;\n    76→      pointerY = e.global.y;\n    77→    });\n    78→  }\n    79→\n    80→  // Stage-level handlers for move and up\n    81→  app.stage.eventMode = \"static\";\n    82→  app.stage.hitArea = app.screen;\n    83→\n    84→  app.stage.on(\"pointermove\", (e: FederatedPointerEvent) => {\n    85→    if (!dragSource) return;\n    86→    pointerX = e.global.x;\n    87→    pointerY = e.global.y;\n    88→    drawPreview();\n    89→  });\n    90→\n    91→  const endDrag = (e: FederatedPointerEvent) => {\n    92→    if (!dragSource) return;\n    93→\n    94→    const dx = e.global.x - dragStartX;\n    95→    const dy = e.global.y - dragStartY;\n    96→    const movedDist = Math.sqrt(dx * dx + dy * dy);\n    97→\n    98→    if (movedDist < TAP_THRESHOLD) {\n    99→      // It's a tap — handle tap-tap selection\n   100→      const tappedBox = hitTest(e.global.x, e.global.y, boxes);\n   101→      if (tappedBox) {\n   102→        if (selectedBoxIndex === null) {\n   103→          // No selection — select this box\n   104→          selectedBoxIndex = tappedBox.index;\n   105→        } else if (selectedBoxIndex === tappedBox.index) {\n   106→          // Same box — deselect\n   107→          selectedBoxIndex = null;\n   108→        } else {\n   109→          // Different box — toggle connection from selected to tapped\n   110→          toggle(selectedBoxIndex, tappedBox.index);\n   111→          selectedBoxIndex = null;\n   112→          redraw();\n   113→        }\n   114→      } else {\n   115→        // Tapped empty space — check if tapped on a line\n   116→        const lineIdx = hitTestLine(e.global.x, e.global.y, connections, boxes);\n   117→        if (lineIdx >= 0) {\n   118→          animateRemoval(app, boxes, connections.splice(lineIdx, 1)[0]!);\n   119→          redraw();\n   120→        }\n   121→        selectedBoxIndex = null;\n   122→      }\n   123→      drawHighlight();\n   124→    } else {\n   125→      // It's a drag — existing behavior\n   126→      const target = hitTest(e.global.x, e.global.y, boxes);\n   127→      if (target && target.index !== dragSource.index) {\n   128→        toggle(dragSource.index, target.index);\n   129→        redraw();\n   130→      }\n   131→    }\n   132→\n   133→    dragSource = null;\n   134→    previewLayer.clear();\n   135→  };\n   136→\n   137→  app.stage.on(\"pointerup\", endDrag);\n   138→  app.stage.on(\"pointerupoutside\", endDrag);\n   139→  app.stage.on(\"pointercancel\", () => {\n   140→    dragSource = null;\n   141→    previewLayer.clear();\n   142→  });\n   143→\n   144→  function drawPreview() {\n   145→    previewLayer.clear();\n   146→    if (!dragSource) return;\n   147→\n   148→    const sx = dragSource.cx;\n   149→    const sy = dragSource.cy;\n   150→    const dx = pointerX - sx;\n   151→    const dy = pointerY - sy;\n   152→    const dist = Math.sqrt(dx * dx + dy * dy);\n   153→    if (dist < 5) return;\n   154→\n   155→    const perpX = -dy / dist;\n   156→    const perpY = dx / dist;\n   157→    const offset = dist * 0.1;\n   158→    const cpX = (sx + pointerX) / 2 + perpX * offset;\n   159→    const cpY = (sy + pointerY) / 2 + perpY * offset;\n   160→\n   161→    previewLayer.moveTo(sx, sy);\n   162→    previewLayer.quadraticCurveTo(cpX, cpY, pointerX, pointerY);\n   163→    previewLayer.stroke({\n   164→      width: PREVIEW_WIDTH,\n   165→      color: PREVIEW_COLOR,\n   166→      alpha: 0.6,\n   167→    });\n   168→  }\n   169→\n   170→  function drawHighlight() {\n   171→    highlightLayer.clear();\n   172→    if (selectedBoxIndex === null) return;\n   173→    const b = boxes[selectedBoxIndex]!;\n   174→    const left = b.cx - b.w / 2;\n   175→    const top = b.cy - b.h / 2;\n   176→    highlightLayer.roundRect(left, top, b.w, b.h, HIGHLIGHT_RADIUS);\n   177→    highlightLayer.fill({ color: SELECTED_COLOR, alpha: 0.15 });\n   178→    highlightLayer.stroke({ width: 2, color: SELECTED_COLOR, alpha: 0.8 });\n   179→  }\n   180→\n   181→  function redraw() {\n   182→    linesLayer.clear();\n   183→    for (const conn of connections) {\n   184→      const source = boxes[conn.source]!;\n   185→      const target = boxes[conn.target]!;\n   186→      drawConnection(linesLayer, source, target);\n   187→    }\n   188→  }\n   189→\n   190→  function resetAll(): Connection[] {\n   191→    const removed = connections.splice(0, connections.length);\n   192→    selectedBoxIndex = null;\n   193→    drawHighlight();\n   194→    redraw();\n   195→    return removed;\n   196→  }\n   197→\n   198→  return { connections, redraw, resetAll };\n   199→}\n   200→\n   201→function getBezierParams(source: BoxInfo, target: BoxInfo) {\n   202→  const dx = target.cx - source.cx;\n   203→  const dy = target.cy - source.cy;\n   204→  const dist = Math.sqrt(dx * dx + dy * dy);\n   205→  if (dist < 1) return null;\n   206→\n   207→  const start = boxEdge(source, target.cx, target.cy);\n   208→  const end = boxEdge(target, source.cx, source.cy);\n   209→\n   210→  const perpX = -dy / dist;\n   211→  const perpY = dx / dist;\n   212→  const offset = dist * CURVE_OFFSET_RATIO;\n   213→\n   214→  const midX = (source.cx + target.cx) / 2;\n   215→  const midY = (source.cy + target.cy) / 2;\n   216→\n   217→  return {\n   218→    start,\n   219→    end,\n   220→    cpX: midX + perpX * offset,\n   221→    cpY: midY + perpY * offset,\n   222→  };\n   223→}\n   224→\n   225→function drawConnection(g: Graphics, source: BoxInfo, target: BoxInfo, color = LINE_COLOR) {\n   226→  const bez = getBezierParams(source, target);\n   227→  if (!bez) return;\n   228→\n   229→  g.moveTo(bez.start.x, bez.start.y);\n   230→  g.quadraticCurveTo(bez.cpX, bez.cpY, bez.end.x, bez.end.y);\n   231→  g.stroke({ width: LINE_WIDTH, color });\n   232→\n   233→  const tdx = bez.end.x - bez.cpX;\n   234→  const tdy = bez.end.y - bez.cpY;\n   235→  const tLen = Math.sqrt(tdx * tdx + tdy * tdy);\n   236→  if (tLen < 1) return;\n   237→\n   238→  const ux = tdx / tLen;\n   239→  const uy = tdy / tLen;\n   240→\n   241→  g.moveTo(bez.end.x, bez.end.y);\n   242→  g.lineTo(\n   243→    bez.end.x - ux * ARROW_SIZE + uy * ARROW_SIZE * 0.4,\n   244→    bez.end.y - uy * ARROW_SIZE - ux * ARROW_SIZE * 0.4,\n   245→  );\n   246→  g.lineTo(\n   247→    bez.end.x - ux * ARROW_SIZE - uy * ARROW_SIZE * 0.4,\n   248→    bez.end.y - uy * ARROW_SIZE + ux * ARROW_SIZE * 0.4,\n   249→  );\n   250→  g.closePath();\n   251→  g.fill({ color });\n   252→}\n   253→\n   254→function hitTestLine(\n   255→  x: number,\n   256→  y: number,\n   257→  connections: Connection[],\n   258→  boxes: BoxInfo[],\n   259→): number {\n   260→  for (let i = 0; i < connections.length; i++) {\n   261→    const conn = connections[i]!;\n   262→    const bez = getBezierParams(boxes[conn.source]!, boxes[conn.target]!);\n   263→    if (!bez) continue;\n   264→\n   265→    for (let t = 0; t <= 1; t += 0.05) {\n   266→      const mt = 1 - t;\n   267→      const px = mt * mt * bez.start.x + 2 * mt * t * bez.cpX + t * t * bez.end.x;\n   268→      const py = mt * mt * bez.start.y + 2 * mt * t * bez.cpY + t * t * bez.end.y;\n   269→      if ((x - px) ** 2 + (y - py) ** 2 < LINE_HIT_THRESHOLD ** 2) return i;\n   270→    }\n   271→  }\n   272→  return -1;\n   273→}\n   274→\n   275→function animateRemoval(\n   276→  app: Application,\n   277→  boxes: BoxInfo[],\n   278→  conn: Connection,\n   279→) {\n   280→  const layer = new Graphics();\n   281→  app.stage.addChild(layer);\n   282→  drawConnection(layer, boxes[conn.source]!, boxes[conn.target]!);\n   283→  layer.alpha = 0.8;\n   284→\n   285→  const fade = () => {\n   286→    layer.alpha -= FADE_SPEED;\n   287→    if (layer.alpha <= 0) {\n   288→      app.ticker.remove(fade);\n   289→      app.stage.removeChild(layer);\n   290→      layer.destroy();\n   291→    }\n   292→  };\n   293→  app.ticker.add(fade);\n   294→}\n   295→\n   296→/** Computes where a ray from the box center toward (toX, toY) exits the box boundary. */\n   297→function boxEdge(\n   298→  box: BoxInfo,\n   299→  toX: number,\n   300→  toY: number,\n   301→): { x: number; y: number } {\n   302→  const dx = toX - box.cx;\n   303→  const dy = toY - box.cy;\n   304→  if (dx === 0 && dy === 0) return { x: box.cx, y: box.cy };\n   305→\n   306→  const halfW = box.w / 2;\n   307→  const halfH = box.h / 2;\n   308→  const scale =\n   309→    Math.abs(dx) / halfW > Math.abs(dy) / halfH\n   310→      ? halfW / Math.abs(dx)\n   311→      : halfH / Math.abs(dy);\n   312→\n   313→  return { x: box.cx + dx * scale, y: box.cy + dy * scale };\n   314→}\n   315→\n   316→function hitTest(x: number, y: number, boxes: BoxInfo[]): BoxInfo | null {\n   317→  for (const box of boxes) {\n   318→    const left = box.cx - box.w / 2;\n   319→    const right = box.cx + box.w / 2;\n   320→    const top = box.cy - box.h / 2;\n   321→    const bottom = box.cy + box.h / 2;\n   322→    if (x >= left && x <= right && y >= top && y <= bottom) {\n   323→      return box;\n   324→    }\n   325→  }\n   326→  return null;\n   327→}\n   328→"}]},"parent_tool_use_id":null,"session_id":"55454d52-f8b7-4bbb-90ac-b6b8c0995947","uuid":"6658daf7-cf2b-4601-8150-a97abc32fc04","tool_use_result":{"type":"text","file":{"filePath":"/Users/jstoone/Sites/linjer/src/connections.ts","content":"import {\n  Application,\n  Graphics,\n  FederatedPointerEvent,\n  Rectangle,\n} from \"pixi.js\";\nimport { BoxInfo } from \"./grid\";\n\nexport interface Connection {\n  source: number;\n  target: number;\n}\n\nconst LINE_COLOR = 0xe94560;\nconst PREVIEW_COLOR = 0x53c28b;\nconst SELECTED_COLOR = 0x53c28b;\nconst LINE_WIDTH = 2.5;\nconst PREVIEW_WIDTH = 2;\nconst ARROW_SIZE = 8;\nconst CURVE_OFFSET_RATIO = 0.15;\nconst TAP_THRESHOLD = 10;\nconst HIGHLIGHT_RADIUS = 10;\nconst LINE_HIT_THRESHOLD = 20;\nconst FADE_SPEED = 0.04;\n\nexport interface ConnectionManager {\n  connections: Connection[];\n  redraw: () => void;\n  resetAll: () => Connection[];\n}\n\n/**\n * Sets up drag-to-connect interaction on the box grid.\n * Returns a ConnectionManager for use by future features (tap-tap, remove, reset).\n */\nexport function setupConnections(\n  app: Application,\n  boxes: BoxInfo[],\n): ConnectionManager {\n  const connections: Connection[] = [];\n  const highlightLayer = new Graphics();\n  const linesLayer = new Graphics();\n  const previewLayer = new Graphics();\n  app.stage.addChild(highlightLayer);\n  app.stage.addChild(linesLayer);\n  app.stage.addChild(previewLayer);\n\n  let dragSource: BoxInfo | null = null;\n  let pointerX = 0;\n  let pointerY = 0;\n  let dragStartX = 0;\n  let dragStartY = 0;\n  let selectedBoxIndex: number | null = null;\n\n  function toggle(source: number, target: number) {\n    const idx = connections.findIndex(\n      c => c.source === source && c.target === target\n    );\n    if (idx >= 0) {\n      animateRemoval(app, boxes, connections.splice(idx, 1)[0]!);\n    } else {\n      connections.push({ source, target });\n    }\n  }\n\n  // Make each box interactive\n  for (const box of boxes) {\n    box.container.eventMode = \"static\";\n    box.container.cursor = \"pointer\";\n    box.container.hitArea = new Rectangle(0, 0, box.w, box.h);\n    box.container.on(\"pointerdown\", (e: FederatedPointerEvent) => {\n      dragSource = box;\n      dragStartX = e.global.x;\n      dragStartY = e.global.y;\n      pointerX = e.global.x;\n      pointerY = e.global.y;\n    });\n  }\n\n  // Stage-level handlers for move and up\n  app.stage.eventMode = \"static\";\n  app.stage.hitArea = app.screen;\n\n  app.stage.on(\"pointermove\", (e: FederatedPointerEvent) => {\n    if (!dragSource) return;\n    pointerX = e.global.x;\n    pointerY = e.global.y;\n    drawPreview();\n  });\n\n  const endDrag = (e: FederatedPointerEvent) => {\n    if (!dragSource) return;\n\n    const dx = e.global.x - dragStartX;\n    const dy = e.global.y - dragStartY;\n    const movedDist = Math.sqrt(dx * dx + dy * dy);\n\n    if (movedDist < TAP_THRESHOLD) {\n      // It's a tap — handle tap-tap selection\n      const tappedBox = hitTest(e.global.x, e.global.y, boxes);\n      if (tappedBox) {\n        if (selectedBoxIndex === null) {\n          // No selection — select this box\n          selectedBoxIndex = tappedBox.index;\n        } else if (selectedBoxIndex === tappedBox.index) {\n          // Same box — deselect\n          selectedBoxIndex = null;\n        } else {\n          // Different box — toggle connection from selected to tapped\n          toggle(selectedBoxIndex, tappedBox.index);\n          selectedBoxIndex = null;\n          redraw();\n        }\n      } else {\n        // Tapped empty space — check if tapped on a line\n        const lineIdx = hitTestLine(e.global.x, e.global.y, connections, boxes);\n        if (lineIdx >= 0) {\n          animateRemoval(app, boxes, connections.splice(lineIdx, 1)[0]!);\n          redraw();\n        }\n        selectedBoxIndex = null;\n      }\n      drawHighlight();\n    } else {\n      // It's a drag — existing behavior\n      const target = hitTest(e.global.x, e.global.y, boxes);\n      if (target && target.index !== dragSource.index) {\n        toggle(dragSource.index, target.index);\n        redraw();\n      }\n    }\n\n    dragSource = null;\n    previewLayer.clear();\n  };\n\n  app.stage.on(\"pointerup\", endDrag);\n  app.stage.on(\"pointerupoutside\", endDrag);\n  app.stage.on(\"pointercancel\", () => {\n    dragSource = null;\n    previewLayer.clear();\n  });\n\n  function drawPreview() {\n    previewLayer.clear();\n    if (!dragSource) return;\n\n    const sx = dragSource.cx;\n    const sy = dragSource.cy;\n    const dx = pointerX - sx;\n    const dy = pointerY - sy;\n    const dist = Math.sqrt(dx * dx + dy * dy);\n    if (dist < 5) return;\n\n    const perpX = -dy / dist;\n    const perpY = dx / dist;\n    const offset = dist * 0.1;\n    const cpX = (sx + pointerX) / 2 + perpX * offset;\n    const cpY = (sy + pointerY) / 2 + perpY * offset;\n\n    previewLayer.moveTo(sx, sy);\n    previewLayer.quadraticCurveTo(cpX, cpY, pointerX, pointerY);\n    previewLayer.stroke({\n      width: PREVIEW_WIDTH,\n      color: PREVIEW_COLOR,\n      alpha: 0.6,\n    });\n  }\n\n  function drawHighlight() {\n    highlightLayer.clear();\n    if (selectedBoxIndex === null) return;\n    const b = boxes[selectedBoxIndex]!;\n    const left = b.cx - b.w / 2;\n    const top = b.cy - b.h / 2;\n    highlightLayer.roundRect(left, top, b.w, b.h, HIGHLIGHT_RADIUS);\n    highlightLayer.fill({ color: SELECTED_COLOR, alpha: 0.15 });\n    highlightLayer.stroke({ width: 2, color: SELECTED_COLOR, alpha: 0.8 });\n  }\n\n  function redraw() {\n    linesLayer.clear();\n    for (const conn of connections) {\n      const source = boxes[conn.source]!;\n      const target = boxes[conn.target]!;\n      drawConnection(linesLayer, source, target);\n    }\n  }\n\n  function resetAll(): Connection[] {\n    const removed = connections.splice(0, connections.length);\n    selectedBoxIndex = null;\n    drawHighlight();\n    redraw();\n    return removed;\n  }\n\n  return { connections, redraw, resetAll };\n}\n\nfunction getBezierParams(source: BoxInfo, target: BoxInfo) {\n  const dx = target.cx - source.cx;\n  const dy = target.cy - source.cy;\n  const dist = Math.sqrt(dx * dx + dy * dy);\n  if (dist < 1) return null;\n\n  const start = boxEdge(source, target.cx, target.cy);\n  const end = boxEdge(target, source.cx, source.cy);\n\n  const perpX = -dy / dist;\n  const perpY = dx / dist;\n  const offset = dist * CURVE_OFFSET_RATIO;\n\n  const midX = (source.cx + target.cx) / 2;\n  const midY = (source.cy + target.cy) / 2;\n\n  return {\n    start,\n    end,\n    cpX: midX + perpX * offset,\n    cpY: midY + perpY * offset,\n  };\n}\n\nfunction drawConnection(g: Graphics, source: BoxInfo, target: BoxInfo, color = LINE_COLOR) {\n  const bez = getBezierParams(source, target);\n  if (!bez) return;\n\n  g.moveTo(bez.start.x, bez.start.y);\n  g.quadraticCurveTo(bez.cpX, bez.cpY, bez.end.x, bez.end.y);\n  g.stroke({ width: LINE_WIDTH, color });\n\n  const tdx = bez.end.x - bez.cpX;\n  const tdy = bez.end.y - bez.cpY;\n  const tLen = Math.sqrt(tdx * tdx + tdy * tdy);\n  if (tLen < 1) return;\n\n  const ux = tdx / tLen;\n  const uy = tdy / tLen;\n\n  g.moveTo(bez.end.x, bez.end.y);\n  g.lineTo(\n    bez.end.x - ux * ARROW_SIZE + uy * ARROW_SIZE * 0.4,\n    bez.end.y - uy * ARROW_SIZE - ux * ARROW_SIZE * 0.4,\n  );\n  g.lineTo(\n    bez.end.x - ux * ARROW_SIZE - uy * ARROW_SIZE * 0.4,\n    bez.end.y - uy * ARROW_SIZE + ux * ARROW_SIZE * 0.4,\n  );\n  g.closePath();\n  g.fill({ color });\n}\n\nfunction hitTestLine(\n  x: number,\n  y: number,\n  connections: Connection[],\n  boxes: BoxInfo[],\n): number {\n  for (let i = 0; i < connections.length; i++) {\n    const conn = connections[i]!;\n    const bez = getBezierParams(boxes[conn.source]!, boxes[conn.target]!);\n    if (!bez) continue;\n\n    for (let t = 0; t <= 1; t += 0.05) {\n      const mt = 1 - t;\n      const px = mt * mt * bez.start.x + 2 * mt * t * bez.cpX + t * t * bez.end.x;\n      const py = mt * mt * bez.start.y + 2 * mt * t * bez.cpY + t * t * bez.end.y;\n      if ((x - px) ** 2 + (y - py) ** 2 < LINE_HIT_THRESHOLD ** 2) return i;\n    }\n  }\n  return -1;\n}\n\nfunction animateRemoval(\n  app: Application,\n  boxes: BoxInfo[],\n  conn: Connection,\n) {\n  const layer = new Graphics();\n  app.stage.addChild(layer);\n  drawConnection(layer, boxes[conn.source]!, boxes[conn.target]!);\n  layer.alpha = 0.8;\n\n  const fade = () => {\n    layer.alpha -= FADE_SPEED;\n    if (layer.alpha <= 0) {\n      app.ticker.remove(fade);\n      app.stage.removeChild(layer);\n      layer.destroy();\n    }\n  };\n  app.ticker.add(fade);\n}\n\n/** Computes where a ray from the box center toward (toX, toY) exits the box boundary. */\nfunction boxEdge(\n  box: BoxInfo,\n  toX: number,\n  toY: number,\n): { x: number; y: number } {\n  const dx = toX - box.cx;\n  const dy = toY - box.cy;\n  if (dx === 0 && dy === 0) return { x: box.cx, y: box.cy };\n\n  const halfW = box.w / 2;\n  const halfH = box.h / 2;\n  const scale =\n    Math.abs(dx) / halfW > Math.abs(dy) / halfH\n      ? halfW / Math.abs(dx)\n      : halfH / Math.abs(dy);\n\n  return { x: box.cx + dx * scale, y: box.cy + dy * scale };\n}\n\nfunction hitTest(x: number, y: number, boxes: BoxInfo[]): BoxInfo | null {\n  for (const box of boxes) {\n    const left = box.cx - box.w / 2;\n    const right = box.cx + box.w / 2;\n    const top = box.cy - box.h / 2;\n    const bottom = box.cy + box.h / 2;\n    if (x >= left && x <= right && y >= top && y <= bottom) {\n      return box;\n    }\n  }\n  return null;\n}\n","numLines":328,"startLine":1,"totalLines":328}}}
